# Note: Column names, paths, and business identifiers were generalized for confidentiality

import pandas as pd
import matplotlib.pyplot as plt

# 1. Load sensor data
df_sensor = pd.read_csv("data/sample_sensor_data.csv")
df_sensor["timestamp"] = pd.to_datetime(df_sensor["timestamp"])

# 2. Identify signal and temperature columns
control_cols = [col for col in df_sensor.columns if "control_signal" in col]
temp_cols = [col for col in df_sensor.columns if "temperature" in col]
print("Control Signal Distribution:")
print(df_sensor[control_cols].describe().T)
print("Temperature Distribution:")
print(df_sensor[temp_cols].describe().T)

# 3. Estimate daily runtime of this system
df_sensor["date"] = df_sensor["timestamp"].dt.date
# Use 0.5 for thresholding
CONTROL_THRESHOLD = 0.5
unit_control_map = {
    "unit_a": ["control_signal_1_unit_a", "control_signal_2_unit_a", "control_signal_3_unit_a"],
    "unit_b": ["control_signal_1_unit_b", "control_signal_2_unit_b", "control_signal_3_unit_b"],
    "unit_c": ["control_signal_1_unit_c", "control_signal_2_unit_c", "control_signal_3_unit_c"],
}
runtime_summary = []
for unit, cols in unit_control_map.items():
    df_sensor[f"{unit}_system_on"] = df_sensor[cols].gt(CONTROL_THRESHOLD).any(axis=1)
    daily_runtime_hours = (df_sensor.groupby("date")[f"{unit}_system_on"].sum() / 60)
    runtime_summary.append({
        "production_unit": unit,
        "avg_runtime_hours_per_day": daily_runtime_hours.mean()})
runtime_summary = pd.DataFrame(runtime_summary)
print(runtime_summary)

# 4. Compare performance between
df_perf = pd.read_csv("data/sample_performance_data.csv")
df_perf["date"] = pd.to_datetime(df_perf["date"])
system_usage_map = {
    "unit_a": "Yes",
    "unit_b": "Yes",
    "unit_c": "No",
    "unit_d": "No"
}
df_perf["system_usage"] = df_perf["production_unit"].map(system_usage_map)
performance_compare = (
    df_perf
    .groupby("system_usage")["final_conversion_rate"]
    .agg(["mean", "median", "std"])
    .reset_index())
print("Performance Comparison:")
print(performance_compare)

# 5. Compare internal vs external temperature
df_external = pd.read_csv("data/sample_external_temperature.csv")
df_external["timestamp_hour"] = pd.to_datetime(df_external["timestamp_hour"])
df_sensor["timestamp_hour"] = df_sensor["timestamp"].dt.floor("h")
internal_hourly = (
    df_sensor
    .groupby("timestamp_hour")[temp_cols]
    .mean()
    .reset_index())
internal_hourly["internal_temp_avg"] = internal_hourly[temp_cols].mean(axis=1)
merged_temp = internal_hourly.merge(
    df_external,
    on="timestamp_hour",
    how="inner")
merged_temp["temperature_gap"] = (merged_temp["external_temp_avg"] - merged_temp["internal_temp_avg"])
print("Temperature Gap Summary:")
print(merged_temp["temperature_gap"].describe())

# 6. Visualization
plt.figure(figsize=(12, 6))
plt.plot(
    merged_temp["timestamp_hour"],
    merged_temp["external_temp_avg"],
    label="External",
    linewidth=1.5)
plt.plot(
    merged_temp["timestamp_hour"],
    merged_temp["internal_temp_avg"],
    label="Internal",
    linewidth=1.5)
plt.title("External vs Internal Temperature")
plt.ylabel("Temperature (°C)")
plt.xlabel("Time")
plt.legend()
plt.tight_layout()
plt.show()
